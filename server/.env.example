# Copie para .env (nunca commite o .env real).

# --- PostgreSQL (Docker) — única forma suportada neste projeto ---
# Na raiz: docker compose up -d
# Na 1ª subida do volume, o Postgres aplica sozinho server/sql/001, 002 e 003 (schema, destinos, admin).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jlturismo

# Se a porta 5432 já estiver em uso, mude em docker-compose.yml (ex.: "5433:5432")
# e ajuste a URL abaixo para localhost:5433

JWT_SECRET=troque-por-uma-chave-longa-e-secreta

PORT=3000
CORS_ORIGIN=http://localhost:5173
